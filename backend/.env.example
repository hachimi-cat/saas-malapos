# Backend config — copy to .env

# Your service identity (must match the service name in @forjio/sdk)
FORJIO_SERVICE=malapos

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/malapos

# Huudis OIDC — set after the product is registered as an OAuth client
HUUDIS_ISSUER=https://huudis.com
HUUDIS_AUDIENCE=malapos

# Admin portal — server-to-server secret for /api/v1/admin/* routes.
# Optional: the admin portal works on its `admin` session cookie alone
# (gated on owner/admin of this product's Huudis workspace). Set this
# only if first-party automation needs to call admin routes without a
# browser session — generate with `openssl rand -hex 32`.
# NOTE: the name is EXACTLY <BRAND>_ADMIN_SECRET (admin-guard.ts reads
# it) — a droplet env set as <BRAND>_FORJIO_ADMIN_SECRET is silently
# ignored and the server-to-server CRM path 401s.
MALAPOS_ADMIN_SECRET=

# HTTP
PORT=4000
NODE_ENV=development

# Outbox worker
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
